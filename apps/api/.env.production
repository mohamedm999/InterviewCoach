# ==============================================
# InterviewCoach API - Production Environment
# ==============================================

NODE_ENV=production
PORT=3000
APP_NAME=InterviewCoach
APP_URL=https://interviewcoach.app

# Database - Use production connection string
DATABASE_URL=

# JWT - Use strong secrets in production
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS - Set production origins
CORS_ORIGINS=https://interviewcoach.app

LOG_LEVEL=info

# Email
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@interviewcoach.app

# LLM Coaching (OpenRouter) - MANDATORY
LLM_COACHING_ENABLED=true
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
LLM_TIMEOUT_MS=30000
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

SWAGGER_ENABLED=false
SWAGGER_PATH=api/docs

THROTTLE_TTL=60
THROTTLE_LIMIT=10

MAX_FILE_SIZE=1048576
UPLOAD_DEST=./uploads
