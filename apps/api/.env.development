# ==============================================
# InterviewCoach API - Development Environment
# ==============================================

NODE_ENV=development
PORT=3000
APP_NAME=InterviewCoach
APP_URL=http://localhost:3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interviewcoach

JWT_ACCESS_SECRET=dev-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-minimum-32-characters-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

CORS_ORIGINS=http://localhost:3001

LOG_LEVEL=debug

# Email — Mailtrap SMTP Sandbox (captures all emails in Mailtrap dashboard)
# Override: disable the Mailtrap API token so SMTP path is used instead
MAILTRAP_TOKEN=
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=35de6c12764bb5
MAIL_PASSWORD=ffb1220f8cb3f2
MAIL_FROM=noreply@interviewcoach.app

# -----------------
# LLM Coaching (OpenRouter) - MANDATORY
# -----------------
LLM_COACHING_ENABLED=true
LLM_PROVIDER=openrouter
# FREE MODEL - NVIDIA Nemotron 3 Nano (30B)
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
LLM_TIMEOUT_MS=60000
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

THROTTLE_TTL=60
THROTTLE_LIMIT=100

MAX_FILE_SIZE=1048576
UPLOAD_DEST=./uploads
