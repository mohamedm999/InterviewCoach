# ==============================================
# InterviewCoach API - Environment Configuration
# ==============================================

# -----------------
# Application
# -----------------
NODE_ENV=development
PORT=3000
APP_NAME=InterviewCoach
APP_URL=http://localhost:3001

# -----------------
# Database
# -----------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interviewcoach

# -----------------
# JWT Authentication
# -----------------
JWT_ACCESS_SECRET=your-access-secret-minimum-32-characters-long-change-this
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-long-change-this
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -----------------
# CORS
# -----------------
CORS_ORIGINS=http://localhost:3001

# -----------------
# Logging
# -----------------
LOG_LEVEL=debug

# -----------------
# Email (Optional)
# -----------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@interviewcoach.app

# -----------------
# OpenAI (Optional)
# -----------------
OPENAI_API_KEY=

# -----------------
# Sentry (Optional)
# -----------------
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------
# Swagger
# -----------------
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# -----------------
# Rate Limiting
# -----------------
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# -----------------
# File Upload
# -----------------
MAX_FILE_SIZE=1048576
UPLOAD_DEST=./uploads
