{
  "name": "interviewcoach",
  "version": "1.0.0",
  "description": "InterviewCoach - AI-powered interview preparation platform",
  "private": true,
  "scripts": {
    "setup:env": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'powershell -ExecutionPolicy Bypass -File ./scripts/setup-env.ps1' : 'bash ./scripts/setup-env.sh', {stdio: 'inherit'})\"",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:runInBand": "turbo run test:runInBand",
    "test:ci": "turbo run test:ci",
    "test:cov": "turbo run test:cov",
    "test:e2e": "turbo run test:e2e",
    "verify": "npm run lint && npm run build:web && npm run test:ci",
    "format": "turbo run format",
    "db:generate": "turbo run db:generate --filter=api",
    "db:migrate": "turbo run db:migrate --filter=api",
    "db:seed": "turbo run db:seed --filter=api",
    "build:api": "turbo run build --filter=api",
    "build:web": "turbo run build --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "test:api": "turbo run test --filter=api",
    "test:web": "turbo run test --filter=web",
    "test:runInBand:api": "turbo run test:runInBand --filter=api",
    "test:runInBand:web": "turbo run test:runInBand --filter=web",
    "test:ci:api": "turbo run test:ci --filter=api",
    "test:ci:web": "turbo run test:ci --filter=web",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose down && docker compose up --build -d",
    "clean": "turbo run clean",
    "clean:all": "npx rimraf node_modules apps/*/node_modules packages/*/node_modules .turbo apps/*/.turbo packages/*/.turbo"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "commonjs",
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^2.8.13"
  },
  "packageManager": "npm@10.0.0"
}
