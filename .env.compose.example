# Copy this file to `.env` before running `docker compose up`.
# Leave no required production secret blank in the real file.

# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=interviewcoach

# API
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
APP_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001

# Optional mail
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@interviewcoach.app

# Optional LLM coaching
LLM_COACHING_ENABLED=false
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
LLM_TIMEOUT_MS=10000
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
